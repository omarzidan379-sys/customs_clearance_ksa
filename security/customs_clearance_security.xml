<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_customs_clearance" model="ir.module.category">
        <field name="name">Customs Clearance</field>
        <field name="description">Manage customs clearance operations</field>
        <field name="sequence">80</field>
    </record>

    <!-- Groups -->
    <record id="group_customs_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_customs_clearance"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_customs_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_customs_clearance"/>
        <field name="implied_ids" eval="[(4, ref('group_customs_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="rule_customs_clearance_company" model="ir.rule">
        <field name="name">Customs Clearance: Multi-Company</field>
        <field name="model_id" ref="model_customs_clearance"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_customs_user'))]"/>
    </record>

</odoo>
