<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ═══ BOND — FORM ═══════════════════════════════════════════════════════ -->
  <record id="view_customs_bond_form" model="ir.ui.view">
    <field name="name">customs.bond.form</field>
    <field name="model">customs.bond</field>
    <field name="arch" type="xml">
      <form string="Customs Bond / Guarantee — كفالة جمركية">
        <header>
          <button name="action_activate"  string="Activate"  type="object" class="btn-primary" invisible="state != 'draft'"/>
          <button name="action_release"   string="Release"   type="object" class="btn-success"
                  invisible="state not in ('active','partially_released')"/>
          <button name="action_forfeit"   string="Forfeit"   type="object" class="btn-danger"
                  invisible="state not in ('active','partially_released')"/>
          <button name="action_expire"    string="Mark Expired" type="object"
                  invisible="state not in ('draft','active')"/>
          <field name="state" widget="statusbar" statusbar_visible="draft,active,released"/>
        </header>
        <sheet>
          <widget name="web_ribbon" title="Released ✓" bg_color="bg-success" invisible="state != 'released'"/>
          <widget name="web_ribbon" title="Forfeited!"  bg_color="bg-danger"  invisible="state != 'forfeited'"/>
          <widget name="web_ribbon" title="EXPIRED"     bg_color="bg-warning" invisible="not is_expired"/>

          <div class="oe_title">
            <label for="name"/>
            <h1><field name="name" readonly="1"/></h1>
          </div>

          <group>
            <group string="Bond Details">
              <field name="bond_type"/>
              <field name="bond_amount"/>
              <field name="currency_id" invisible="1"/>
              <field name="bond_reference"/>
              <field name="sadad_ref"/>
            </group>
            <group string="Parties">
              <field name="partner_id"/>
              <field name="guarantor_id"/>
              <field name="clearance_id"/>
              <field name="customs_office_id"/>
            </group>
          </group>

          <group>
            <group string="Validity Period">
              <field name="issue_date"/>
              <field name="expiry_date"/>
              <field name="days_to_expiry" readonly="1" widget="integer"
                     decoration-danger="days_to_expiry &lt; 30"
                     decoration-warning="days_to_expiry &lt; 60"/>
              <field name="is_expired" readonly="1"/>
            </group>
            <group string="Release Details" invisible="state not in ('released','partially_released','forfeited')">
              <field name="release_date"/>
              <field name="release_reference"/>
              <field name="released_amount"/>
              <field name="forfeiture_reason" invisible="state != 'forfeited'"/>
            </group>
          </group>

          <group string="Bond Content">
            <field name="goods_description" nolabel="1" placeholder="Description of bonded goods…"/>
          </group>
          <group string="Conditions">
            <field name="conditions" nolabel="1" placeholder="Bond terms and conditions…"/>
          </group>
          <field name="notes" placeholder="Internal notes…"/>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="activity_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <!-- ═══ BOND — LIST ═══════════════════════════════════════════════════════ -->
  <record id="view_customs_bond_list" model="ir.ui.view">
    <field name="name">customs.bond.list</field>
    <field name="model">customs.bond</field>
    <field name="arch" type="xml">
      <tree string="Customs Bonds" decoration-danger="is_expired or state == 'forfeited'"
            decoration-success="state == 'released'" decoration-warning="days_to_expiry &lt; 30 and state == 'active'">
        <field name="is_expired" invisible="1"/>
        <field name="name"/>
        <field name="bond_type"/>
        <field name="partner_id"/>
        <field name="guarantor_id" optional="show"/>
        <field name="clearance_id"/>
        <field name="bond_amount"/>
        <field name="issue_date"/>
        <field name="expiry_date"/>
        <field name="days_to_expiry" string="Days Left"/>
        <field name="state" widget="badge"
               decoration-success="state == 'released'"
               decoration-warning="state in ('active','partially_released')"
               decoration-danger="state in ('forfeited','expired')"/>
      </tree>
    </field>
  </record>

  <!-- ═══ BOND — SEARCH ════════════════════════════════════════════════════ -->
  <record id="view_customs_bond_search" model="ir.ui.view">
    <field name="name">customs.bond.search</field>
    <field name="model">customs.bond</field>
    <field name="arch" type="xml">
      <search string="Customs Bonds">
        <field name="name"/>
        <field name="partner_id"/>
        <field name="clearance_id"/>
        <field name="bond_reference"/>
        <filter name="active"    string="Active"    domain="[('state','=','active')]"/>
        <filter name="expired"   string="Expired"   domain="[('is_expired','=',True)]"/>
        <filter name="released"  string="Released"  domain="[('state','=','released')]"/>
        <filter name="forfeited" string="Forfeited" domain="[('state','=','forfeited')]"/>
        <separator/>
        <filter name="bank_guarantee" string="Bank Guarantees" domain="[('bond_type','=','bank_guarantee')]"/>
        <filter name="aeo_global"     string="AEO Global"      domain="[('bond_type','=','aeo_global')]"/>
        <group expand="0" string="Group By">
          <filter name="by_type"    string="Bond Type" context="{'group_by': 'bond_type'}"/>
          <filter name="by_partner" string="Importer"  context="{'group_by': 'partner_id'}"/>
          <filter name="by_state"   string="Status"    context="{'group_by': 'state'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- ═══ ACTION ════════════════════════════════════════════════════════════ -->
  <record id="action_customs_bond" model="ir.actions.act_window">
    <field name="name">Customs Bonds — الكفالات الجمركية</field>
    <field name="res_model">customs.bond</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_customs_bond_search"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">No bonds registered yet</p>
      <p>Track cash, bank, and documentary customs guarantees as required
         by ZATCA for temporary imports, transits, and AEO operations.</p>
    </field>
  </record>

</odoo>
