<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_customs_broker_form" model="ir.ui.view">
    <field name="name">customs.broker.form.ksa</field>
    <field name="model">customs.broker</field>
    <field name="arch" type="xml">
      <form string="Customs Broker — KSA">
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="action_view_clearances" type="object"
                    class="oe_stat_button" icon="fa-file-text">
              <field name="clearance_count" widget="statinfo" string="Clearances"/>
            </button>
          </div>
          <widget name="web_ribbon" title="License Expired!" bg_color="bg-danger"
                  invisible="not license_expired"/>
          <div class="oe_title"><h1><field name="name"/></h1></div>
          <group>
            <group string="Broker Details">
              <field name="partner_id"/>
              <field name="license_number"/>
              <field name="license_expiry_date"/>
              <field name="license_expired" widget="boolean_toggle" readonly="1"/>
              <field name="specialization"/>
            </group>
            <group string="Saudi ZATCA Details">
              <field name="zatca_broker_code"/>
              <field name="fasah_username"/>
              <field name="is_aeo_broker"/>
              <field name="aeo_cert_no" invisible="not is_aeo_broker"/>
            </group>
          </group>
          <group>
            <group string="Service Fees">
              <field name="service_fee_type"/>
              <field name="service_fee"/>
            </group>
          </group>
          <group>
            <field name="customs_office_ids" widget="many2many_tags"/>
          </group>
          <field name="notes"/>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>
  <record id="view_customs_broker_list" model="ir.ui.view">
    <field name="name">customs.broker.list.ksa</field>
    <field name="model">customs.broker</field>
    <field name="arch" type="xml">
      <tree decoration-danger="license_expired">
        <field name="name"/>
        <field name="partner_id"/>
        <field name="license_number"/>
        <field name="license_expiry_date"/>
        <field name="license_expired" widget="boolean_toggle"/>
        <field name="zatca_broker_code" optional="show"/>
        <field name="is_aeo_broker" optional="show"/>
        <field name="specialization" widget="badge"/>
        <field name="clearance_count" string="Clearances"/>
      </tree>
    </field>
  </record>
  <record id="action_customs_broker" model="ir.actions.act_window">
    <field name="name">Customs Brokers / المخلصون الجمركيون</field>
    <field name="res_model">customs.broker</field>
    <field name="view_mode">tree,form</field>
  </record>
</odoo>
