<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ═══ FORM VIEW ════════════════════════════════════════════════════════ -->
  <record id="view_customs_portal_request_form" model="ir.ui.view">
    <field name="name">customs.portal.request.form</field>
    <field name="model">customs.portal.request</field>
    <field name="arch" type="xml">
      <form string="Portal Shipment Request">
        <header>
          <button name="action_start_review" string="Start Review" type="object"
                  class="btn-primary" invisible="state != 'draft'"/>
          <button name="action_approve" string="Approve &amp; Create Order" type="object"
                  class="btn-success" invisible="state != 'review'"/>
          <button name="action_reject" string="Reject" type="object"
                  class="btn-danger" invisible="state not in ('draft','review')"/>
          <button name="action_reset_draft" string="Reset" type="object"
                  invisible="state != 'rejected'"/>
          <button name="action_view_clearance" string="View Clearance Order" type="object"
                  class="btn-secondary" invisible="not clearance_id"/>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft,review,approved"/>
        </header>
        <sheet>
<!--          <div class="oe_button_box" name="button_box">-->
<!--            <button type="object" class="oe_stat_button" icon="fa-paperclip"-->
<!--                    name="%(base_setup.action_general_configuration)d">-->
<!--              <field name="attachment_count" widget="statinfo" string="Files"/>-->
<!--            </button>-->
<!--          </div>-->
          <widget name="web_ribbon" title="Approved ✓" bg_color="bg-success"
                  invisible="state != 'approved'"/>
          <widget name="web_ribbon" title="Rejected" bg_color="bg-danger"
                  invisible="state != 'rejected'"/>

          <div class="oe_title">
            <label for="name"/>
            <h1><field name="name" readonly="1"/></h1>
            <field name="priority" widget="priority"/>
          </div>

          <group>
            <group string="Requester Information">
              <field name="request_type" widget="badge"/>
              <field name="requester_name"/>
              <field name="requester_email"/>
              <field name="requester_phone"/>
              <field name="requester_company"/>
              <field name="requester_cr_no"/>
              <field name="requester_vat_no"/>
              <field name="requester_country"/>
              <field name="requester_city"/>
              <field name="partner_id"/>
            </group>
            <group string="Shipment Details">
              <field name="clearance_type" widget="badge"/>
              <field name="shipment_type"/>
              <field name="country_origin_id"/>
              <field name="country_destination_id"/>
              <field name="port_of_loading"/>
              <field name="port_of_discharge"/>
              <field name="vessel_name"/>
              <field name="bill_of_lading_no"/>
              <field name="eta"/>
              <field name="gross_weight"/>
              <field name="volume"/>
              <field name="packages_count"/>
            </group>
          </group>

          <notebook>
            <page string="Goods &amp; HS Codes" name="goods">
              <group>
                <field name="goods_description" colspan="2"/>
                <field name="hs_codes_list" colspan="2"/>
                <field name="estimated_value"/>
                <field name="currency_note"/>
              </group>
            </page>

            <page string="Documents Submitted" name="documents">
              <group string="Documents Available">
                <field name="has_bill_of_lading" widget="boolean_toggle"/>
                <field name="has_invoice" widget="boolean_toggle"/>
                <field name="has_packing_list" widget="boolean_toggle"/>
                <field name="has_coo" widget="boolean_toggle"/>
                <field name="has_saber_scoc" widget="boolean_toggle"/>
                <field name="has_sfda" widget="boolean_toggle"/>
                <field name="has_citc" widget="boolean_toggle"/>
              </group>
              <group string="Saudi References (if known)">
                <field name="acd_reference_no"/>
                <field name="saber_scoc_no"/>
                <field name="sfda_approval_no"/>
                <field name="fatoorah_invoice_no"/>
              </group>
              <group>
                <field name="additional_docs" colspan="2"/>
              </group>
              <field name="attachment_ids" widget="many2many_binary"/>
            </page>

            <page string="Review &amp; Decision" name="review">
              <group>
                <field name="reviewed_by" readonly="1"/>
                <field name="review_date" readonly="1"/>
              </group>
              <group string="Review Notes (required before approving)">
                <field name="review_notes" colspan="2"
                       placeholder="Add your review notes here. These will be included in the clearance order internal notes and sent to the requester..."/>
              </group>
              <group string="Rejection Reason (required before rejecting)">
                <field name="rejection_reason" colspan="2"
                       placeholder="Explain clearly why this request is being rejected and what the requester needs to do to resubmit..."/>
              </group>
              <group string="Created Clearance Order" invisible="not clearance_id">
                <field name="clearance_id" readonly="1"/>
              </group>
            </page>

            <page string="Submission Info" name="meta">
              <group>
                <field name="portal_token" readonly="1"/>
                <field name="submission_ip" readonly="1"/>
              </group>
            </page>
          </notebook>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <!-- ═══ LIST VIEW ════════════════════════════════════════════════════════ -->
  <record id="view_customs_portal_request_list" model="ir.ui.view">
    <field name="name">customs.portal.request.list</field>
    <field name="model">customs.portal.request</field>
    <field name="arch" type="xml">
      <tree string="Portal Shipment Requests"
            decoration-success="state == 'approved'"
            decoration-danger="state == 'rejected'"
            decoration-warning="state == 'review'"
            decoration-info="state == 'draft'">
        <field name="name"/>
        <field name="create_date" string="Submitted"/>
        <field name="request_type" widget="badge"/>
        <field name="requester_company"/>
        <field name="requester_email"/>
        <field name="clearance_type" widget="badge"/>
        <field name="shipment_type"/>
        <field name="country_origin_id"/>
        <field name="eta"/>
        <field name="estimated_value" string="Est. Value (USD)"/>
        <field name="reviewed_by" optional="show"/>
        <field name="state" widget="badge"
               decoration-success="state == 'approved'"
               decoration-danger="state == 'rejected'"
               decoration-warning="state == 'review'"
               decoration-info="state == 'draft'"/>
        <field name="priority" widget="priority" optional="show"/>
        <field name="clearance_id" optional="show"/>
      </tree>
    </field>
  </record>

  <!-- ═══ KANBAN VIEW ══════════════════════════════════════════════════════ -->
  <record id="view_customs_portal_request_kanban" model="ir.ui.view">
    <field name="name">customs.portal.request.kanban</field>
    <field name="model">customs.portal.request</field>
    <field name="arch" type="xml">
      <kanban default_group_by="state" quick_create="false">
        <field name="name"/><field name="requester_company"/>
        <field name="clearance_type"/><field name="state"/>
        <field name="create_date"/><field name="priority"/>
        <field name="estimated_value"/>
        <templates>
          <t t-name="kanban-box">
            <div class="oe_kanban_details">
              <strong><field name="name"/></strong>
              <div><field name="requester_company"/></div>
              <div><field name="clearance_type"/> — <field name="shipment_type"/></div>
              <div class="text-muted" style="font-size:11px;">
                <field name="create_date" widget="date"/>
              </div>
              <div class="oe_kanban_bottom_right">
                <field name="priority" widget="priority"/>
              </div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

