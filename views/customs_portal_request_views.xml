  <!-- ═══ ACTION ═══════════════════════════════════════════════════════════ -->
  <record id="action_customs_portal_requests" model="ir.actions.act_window">
    <field name="name">Portal Shipment Requests</field>
    <field name="res_model">customs.portal.request</field>
    <field name="view_mode">tree,kanban,form</field>
<!--    <field name="search_view_id" ref="view_customs_portal_request_search"/>-->
<!--    <field name="context">{'search_default_new': 1}</field>-->
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">No portal requests yet</p>
      <p>Requests submitted by suppliers and customers through the portal will appear here for review.</p>
    </field>
  </record>

  <record id="action_portal_requests_pending" model="ir.actions.act_window">
    <field name="name">Pending Review</field>
    <field name="res_model">customs.portal.request</field>
    <field name="view_mode">tree,kanban,form</field>
    <field name="domain">[('state','in',['draft','review'])]</field>
    <field name="context">{'search_default_new': 1}</field>
  </record>

  <!-- ═══ EMAIL TEMPLATES ══════════════════════════════════════════════════ -->
  <record id="email_template_portal_request_received" model="mail.template">
    <field name="name">Portal Request — Received Confirmation</field>
    <field name="model_id" ref="model_customs_portal_request"/>
    <field name="subject">Your Shipment Registration Received — {{ object.name }}</field>
    <field name="email_to">{{ object.requester_email }}</field>
    <field name="body_html"><![CDATA[
      <div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;">
        <div style="background:#1A3A5C;padding:24px;text-align:center;">
          <h2 style="color:white;margin:0;">Customs Clearance Portal</h2>
          <p style="color:#D6EAF8;margin:8px 0 0;">نظام التخليص الجمركي</p>
        </div>
        <div style="padding:24px;background:#f9f9f9;">
          <p>Dear <strong>{{ object.requester_name }}</strong>,</p>
          <p>Thank you for submitting your shipment registration request. We have received it successfully.</p>
          <div style="background:white;border:1px solid #ddd;border-radius:8px;padding:16px;margin:16px 0;">
            <p><strong>Reference:</strong> {{ object.name }}</p>
            <p><strong>Type:</strong> {{ object.clearance_type }}</p>
            <p><strong>Company:</strong> {{ object.requester_company }}</p>
            <p><strong>Submitted:</strong> {{ object.create_date }}</p>
            <p style="margin:16px 0 0;"><strong>Track your request:</strong><br/>
               <a href="{{ ctx.get('base_url','') }}/customs-portal/status/{{ object.portal_token }}"
                  style="color:#1F6FAB;">Click here to check status</a>
            </p>
          </div>
          <p>Our customs team will review your request and respond within 1–2 business days.</p>
          <p style="color:#888;font-size:12px;">Please keep your reference number: <strong>{{ object.name }}</strong></p>
        </div>
      </div>
    ]]></field>
  </record>

  <record id="email_template_portal_request_approved" model="mail.template">
    <field name="name">Portal Request — Approved</field>
    <field name="model_id" ref="model_customs_portal_request"/>
    <field name="subject">Shipment Request Approved — {{ object.name }}</field>
    <field name="email_to">{{ object.requester_email }}</field>
    <field name="body_html"><![CDATA[
      <div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;">
        <div style="background:#1A6B35;padding:24px;text-align:center;">
          <h2 style="color:white;margin:0;">✓ Request Approved</h2>
          <p style="color:#D5F5E3;margin:8px 0 0;">تم قبول الطلب</p>
        </div>
        <div style="padding:24px;background:#f9f9f9;">
          <p>Dear <strong>{{ object.requester_name }}</strong>,</p>
          <p>Your shipment registration request <strong>{{ object.name }}</strong> has been <strong style="color:#1A6B35;">approved</strong>.</p>
          <p>A customs clearance order has been created: <strong>{{ object.clearance_id.name }}</strong></p>
          {% if object.review_notes %}
          <div style="background:#D5F5E3;border-left:4px solid #1A6B35;padding:12px;margin:16px 0;">
            <strong>Notes from our team:</strong><br/>{{ object.review_notes }}
          </div>
          {% endif %}
          <p>Our team will contact you shortly to proceed with the clearance process.</p>
        </div>
      </div>
    ]]></field>
  </record>

  <record id="email_template_portal_request_rejected" model="mail.template">
    <field name="name">Portal Request — Rejected</field>
    <field name="model_id" ref="model_customs_portal_request"/>
    <field name="subject">Shipment Request Requires Updates — {{ object.name }}</field>
    <field name="email_to">{{ object.requester_email }}</field>
    <field name="body_html"><![CDATA[
      <div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;">
        <div style="background:#922B21;padding:24px;text-align:center;">
          <h2 style="color:white;margin:0;">Request Needs Attention</h2>
          <p style="color:#FDEDEC;margin:8px 0 0;">يحتاج الطلب إلى مراجعة</p>
        </div>
        <div style="padding:24px;background:#f9f9f9;">
          <p>Dear <strong>{{ object.requester_name }}</strong>,</p>
          <p>After reviewing your shipment registration <strong>{{ object.name }}</strong>, our team requires the following updates before we can proceed:</p>
          <div style="background:#FDEDEC;border-left:4px solid #922B21;padding:12px;margin:16px 0;">
            <strong>Reason:</strong><br/>{{ object.rejection_reason }}
          </div>
          <p>Please resubmit your request with the required information through the portal.</p>
          <p><a href="{{ ctx.get('base_url','') }}/customs-portal/register"
                style="background:#1F6FAB;color:white;padding:10px 20px;border-radius:4px;text-decoration:none;">
             Submit New Request
          </a></p>
        </div>
      </div>
    ]]></field>
  </record>

</odoo>
