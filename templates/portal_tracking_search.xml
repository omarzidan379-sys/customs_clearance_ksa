<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!-- ═══════════════════════════════════════════════════════════════════════
     TRACKING SEARCH LANDING  —  /customs-portal/tracking
     Dark naval style matching the tracking detail dashboard.
═══════════════════════════════════════════════════════════════════════ -->
<template id="portal_tracking_search" name="Shipment Tracking Search">
<t t-call="website.layout">
<t t-set="title">Track Your Shipment — Customs Clearance KSA</t>

<style>
*{box-sizing:border-box;}
body{background:#020c1a;color:#e2e8f0;}
.trs-bg{position:fixed;inset:0;z-index:0;overflow:hidden;
  background:radial-gradient(ellipse 70% 60% at 20% 50%,rgba(12,20,70,.85) 0,transparent 65%),
             radial-gradient(ellipse 55% 70% at 80% 20%,rgba(8,30,65,.8) 0,transparent 60%),#020c1a;}
.trs-blob{position:absolute;border-radius:50%;filter:blur(80px);opacity:.4;animation:blobDrift linear infinite;}
.trs-blob--1{width:520px;height:520px;background:radial-gradient(circle,rgba(14,165,233,.28) 0,transparent 68%);top:-10%;left:-5%;animation-duration:22s;}
.trs-blob--2{width:420px;height:420px;background:radial-gradient(circle,rgba(99,102,241,.22) 0,transparent 68%);bottom:-15%;right:-5%;animation-duration:28s;animation-delay:-10s;animation-direction:reverse;}
@keyframes blobDrift{0%,100%{transform:translate(0,0) scale(1)}25%{transform:translate(25px,-18px) scale(1.04)}50%{transform:translate(-15px,22px) scale(.96)}75%{transform:translate(15px,10px) scale(1.02)}}

.trs-page{position:relative;z-index:1;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px;}

/* Topbar */
.trs-topbar{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(2,12,26,.85);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,.06);padding:0 24px;}
.trs-topbar-inner{max-width:1100px;margin:0 auto;height:60px;display:flex;align-items:center;justify-content:space-between;}
.trs-brand{display:flex;align-items:center;gap:10px;text-decoration:none;}
.trs-brand-ico{width:34px;height:34px;border-radius:8px;background:rgba(13,110,253,.3);border:1px solid rgba(13,110,253,.5);display:flex;align-items:center;justify-content:center;font-size:15px;}
.trs-brand strong{color:#fff;font-size:14px;font-weight:800;}
.trs-brand span{color:#7a9cc0;font-size:11px;display:block;}
.trs-nav-links{display:flex;gap:8px;}
.trs-nav-link{padding:6px 14px;border-radius:7px;font-size:12px;font-weight:700;text-decoration:none;border:1px solid rgba(255,255,255,.15);color:#94a3b8;transition:all .2s;}
.trs-nav-link:hover{background:rgba(255,255,255,.08);color:#fff;}
.trs-nav-link.primary{background:rgba(13,110,253,.25);border-color:rgba(13,110,253,.5);color:#7dd3fc;}
.trs-nav-link.primary:hover{background:rgba(13,110,253,.4);color:#fff;}

/* Hero content */
.trs-hero{text-align:center;margin-bottom:40px;padding-top:40px;}
.trs-badge{display:inline-flex;align-items:center;gap:7px;padding:5px 14px;background:rgba(14,165,233,.08);border:1px solid rgba(14,165,233,.2);border-radius:100px;font-size:11px;font-weight:700;color:#38d9f5;letter-spacing:.08em;text-transform:uppercase;margin-bottom:16px;}
.trs-badge__dot{width:6px;height:6px;border-radius:50%;background:#10b981;box-shadow:0 0 6px #10b981;animation:pulseDot 2.4s ease infinite;}
@keyframes pulseDot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.7)}}
.trs-title{font-size:clamp(26px,5vw,52px);font-weight:900;letter-spacing:-.04em;background:linear-gradient(135deg,#fff 0%,#bae6fd 45%,#38d9f5 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:10px;}
.trs-subtitle{font-size:14px;color:#475569;max-width:440px;margin:0 auto;}

/* Search card */
.trs-card{background:rgba(8,18,38,.75);backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:36px 32px;width:100%;max-width:520px;box-shadow:0 24px 60px rgba(0,0,0,.5);}
.trs-card::before{content:'';display:block;height:1px;background:linear-gradient(90deg,transparent,rgba(14,165,233,.45),transparent);margin:-36px -32px 28px;}
.trs-card-title{font-size:13px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.08em;margin-bottom:18px;}
.trs-input-wrap{position:relative;margin-bottom:14px;}
.trs-input{width:100%;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.12);border-radius:12px;padding:14px 50px 14px 18px;font-size:15px;font-weight:600;color:#f1f5f9;outline:none;transition:border .2s,background .2s;font-family:inherit;}
.trs-input::placeholder{color:#334155;font-weight:400;}
.trs-input:focus{border-color:rgba(14,165,233,.5);background:rgba(14,165,233,.04);}
.trs-input-icon{position:absolute;right:16px;top:50%;transform:translateY(-50%);font-size:18px;pointer-events:none;}
.trs-btn{width:100%;padding:15px;background:linear-gradient(135deg,#0369a1,#0ea5e9);border:none;border-radius:12px;color:#fff;font-size:15px;font-weight:800;cursor:pointer;letter-spacing:-.01em;transition:opacity .2s,transform .1s;font-family:inherit;}
.trs-btn:hover{opacity:.9;transform:translateY(-1px);}
.trs-btn:active{transform:translateY(0);}
.trs-hint{font-size:11.5px;color:#334155;margin-top:10px;text-align:center;}
.trs-hint span{color:#7dd3fc;}

/* Error */
.trs-error{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);border-radius:12px;padding:12px 16px;margin-bottom:18px;font-size:13px;color:#fca5a5;display:flex;align-items:center;gap:8px;}

/* Stats strip */
.trs-stats{display:flex;gap:12px;margin-top:20px;justify-content:center;flex-wrap:wrap;}
.trs-stat{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:12px 20px;text-align:center;}
.trs-stat__num{font-size:22px;font-weight:900;color:#38bdf8;letter-spacing:-.03em;}
.trs-stat__label{font-size:10px;color:#475569;font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-top:2px;}

/* Divider */
.trs-divider{display:flex;align-items:center;gap:12px;margin:18px 0;}
.trs-divider::before,.trs-divider::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.07);}
.trs-divider span{font-size:11px;color:#334155;font-weight:600;}

/* Quick links */
.trs-quick{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
.trs-quick-btn{padding:8px 16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:8px;color:#94a3b8;font-size:12px;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:all .2s;}
.trs-quick-btn:hover{background:rgba(255,255,255,.09);color:#e2e8f0;}
</style>

<div class="trs-bg">
  <div class="trs-blob trs-blob--1"></div>
  <div class="trs-blob trs-blob--2"></div>
</div>

<div class="trs-topbar">
  <div class="trs-topbar-inner">
    <a class="trs-brand" href="/customs-portal">
      <div class="trs-brand-ico">&#x1F6F3;</div>
      <div>
        <strong>KSA Customs</strong>
        <span>&#x627;&#x644;&#x62C;&#x645;&#x627;&#x631;&#x643; &#x627;&#x644;&#x633;&#x639;&#x648;&#x62F;&#x64A;&#x629;</span>
      </div>
    </a>
    <div class="trs-nav-links">
      <a class="trs-nav-link" href="/customs-portal">&#x2190; Portal</a>
      <a class="trs-nav-link primary" href="/customs-portal/register">New Request</a>
    </div>
  </div>
</div>

<div class="trs-page">
  <div class="trs-hero">
    <div class="trs-badge">
      <div class="trs-badge__dot"></div>
      Live Tracking
    </div>
    <div class="trs-title">Track Your Shipment</div>
    <div class="trs-subtitle">Enter your reference number or tracking token to view real-time status</div>
  </div>

  <div class="trs-card">
    <div class="trs-card-title">&#x1F50D; Shipment Lookup</div>

    <t t-if="error">
      <div class="trs-error">&#x26A0; <span t-out="error"/></div>
    </t>

    <form method="GET" action="/customs-portal/tracking">
      <div class="trs-input-wrap">
        <input
          class="trs-input"
          type="text"
          name="ref"
          t-att-value="ref or ''"
          placeholder="e.g. CCK-2026-00042 or your token"
          autofocus="autofocus"
          autocomplete="off"
        />
        <span class="trs-input-icon">&#x1F6F3;</span>
      </div>
      <button class="trs-btn" type="submit">Track Shipment &#x2192;</button>
      <div class="trs-hint">Enter the <span>reference number</span> or <span>tracking token</span> from your confirmation email</div>
    </form>

    <div class="trs-divider"><span>quick links</span></div>
    <div class="trs-quick">
      <a class="trs-quick-btn" href="/customs-portal/register">&#x2795; New Request</a>
      <a class="trs-quick-btn" href="/customs-portal/status">&#x1F4CB; Check Status</a>
      <a class="trs-quick-btn" href="/customs-portal">&#x1F3E0; Portal Home</a>
    </div>
  </div>

  <div class="trs-stats">
    <div class="trs-stat">
      <div class="trs-stat__num">ZATCA</div>
      <div class="trs-stat__label">Compliant</div>
    </div>
    <div class="trs-stat">
      <div class="trs-stat__num">FASAH</div>
      <div class="trs-stat__label">Integrated</div>
    </div>
    <div class="trs-stat">
      <div class="trs-stat__num">24/7</div>
      <div class="trs-stat__label">Live Updates</div>
    </div>
    <div class="trs-stat">
      <div class="trs-stat__num">KSA</div>
      <div class="trs-stat__label">All Ports</div>
    </div>
  </div>
</div>

</t>
</template>
</odoo>
