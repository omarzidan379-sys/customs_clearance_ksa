<style>
/* ── Extra overrides for gateway right panel ── */
.cck-gateway-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 50px 40px;
    width: 100%;
}
.gw-card-hdr {
    text-align: center;
    margin-bottom: 10px;
}
.gw-logo-ring {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(30,95,168,.35), rgba(11,184,150,.25));
    border: 1px solid rgba(30,95,168,.4);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 18px;
    box-shadow: 0 0 40px rgba(30,95,168,.25);
}
.gw-logo-ring svg { width: 36px; height: 36px; }
.gw-title {
    font-size: 22px; font-weight: 800;
    color: #e8f0f8; letter-spacing: -.4px;
    margin-bottom: 6px;
}
.gw-sub {
    font-size: 13px; color: #8a99ae; line-height: 1.5;
}
.gw-status {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(11,184,150,.08); border: 1px solid rgba(11,184,150,.2);
    border-radius: 999px; padding: 5px 14px;
    font-size: 11px; color: #0bb896; font-weight: 600;
    letter-spacing: .4px; margin-top: 12px;
}
.gw-status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #0bb896;
    box-shadow: 0 0 6px #0bb896;
    animation: statusPulse 2s ease-in-out infinite;
}
@keyframes statusPulse {
    0%,100% { box-shadow: 0 0 4px #0bb896; }
    50%      { box-shadow: 0 0 12px #0bb896, 0 0 20px rgba(11,184,150,.4); }
}
.gw-divider {
    width: 100%; display: flex; align-items: center; gap: 12px;
    margin: 4px 0;
}
.gw-divider-line { flex: 1; height: 1px; background: rgba(30,95,168,.2); }
.gw-divider-text { font-size: 11px; color: #4a5e75; font-weight: 600; letter-spacing: .5px; white-space: nowrap; }

/* ── Gateway Buttons ── */
.gw-btn {
    display: flex; align-items: center; gap: 16px;
    width: 100%; padding: 20px 24px;
    border-radius: 16px; text-decoration: none;
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 15px; font-weight: 700;
    position: relative; overflow: hidden;
    transition: all .35s cubic-bezier(.34,1.56,.64,1);
    border: 1.5px solid transparent;
}
.gw-btn:hover { transform: translateY(-3px) scale(1.01); }
.gw-btn-portal {
    background: linear-gradient(135deg, #1e5fa8 0%, #0bb896 100%);
    color: #fff;
    box-shadow: 0 8px 30px rgba(30,95,168,.35);
    border-color: rgba(255,255,255,.1);
}
.gw-btn-portal:hover {
    box-shadow: 0 14px 45px rgba(11,184,150,.45);
    color: #fff;
}
.gw-btn-system {
    background: rgba(255,255,255,.04);
    color: #e8f0f8;
    border-color: rgba(30,95,168,.3);
}
.gw-btn-system:hover {
    background: rgba(30,95,168,.12);
    border-color: rgba(30,95,168,.55);
    color: #e8f0f8;
    box-shadow: 0 10px 35px rgba(30,95,168,.2);
}
.gw-btn-shine {
    position: absolute; inset: 0;
    background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,.15) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform .6s;
}
.gw-btn-portal:hover .gw-btn-shine { transform: translateX(100%); }
.gw-btn-ico {
    width: 46px; height: 46px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.gw-btn-ico-portal { background: rgba(255,255,255,.2); }
.gw-btn-ico-system { background: rgba(30,95,168,.2); }
.gw-btn-ico svg { width: 22px; height: 22px; }
.gw-btn-text { flex: 1; display: flex; flex-direction: column; gap: 2px; text-align: left; }
.gw-btn-text strong { font-size: 15px; font-weight: 800; display: block; }
.gw-btn-text small { font-size: 11px; opacity: .65; font-weight: 400; }
.gw-btn-arr { opacity: .55; transition: transform .3s, opacity .3s; flex-shrink: 0; }
.gw-btn-arr svg { width: 18px; height: 18px; }
.gw-btn:hover .gw-btn-arr { transform: translateX(5px); opacity: 1; }

/* ── Footer badges ── */
.gw-footer-badges {
    display: flex; gap: 8px; flex-wrap: wrap; justify-content: center;
    margin-top: 8px;
}
.gw-fb {
