<script>
<![CDATA[
(function(){
    /* ── Canvas particle animation (same as login) ── */
    var c = document.getElementById('cck-canvas');
    if (!c) return;
    var ctx = c.getContext('2d'), W, H;
    function resize(){ W = c.width = window.innerWidth; H = c.height = window.innerHeight; }
    resize(); window.addEventListener('resize', resize);
    var cols = ['rgba(30,95,168,','rgba(11,184,150,','rgba(77,168,255,','rgba(14,157,130,'];
    var pts = [];
    for (var i = 0; i < 100; i++) {
        pts.push({ x:Math.random()*W, y:Math.random()*H, vx:(Math.random()-.5)*.25, vy:(Math.random()-.5)*.25,
                   r:Math.random()*1.5+.4, a:Math.random()*.4+.08, c:cols[Math.floor(Math.random()*cols.length)] });
    }
    function draw(){
        ctx.clearRect(0,0,W,H);
        pts.forEach(function(p){
            p.x+=p.vx; p.y+=p.vy;
            if(p.x<0||p.x>W) p.vx*=-1;
            if(p.y<0||p.y>H) p.vy*=-1;
            ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
            ctx.fillStyle=p.c+p.a+')'; ctx.fill();
        });
        for(var a=0;a<pts.length;a++){
            for(var b=a+1;b<pts.length;b++){
                var dx=pts[a].x-pts[b].x, dy=pts[a].y-pts[b].y, d=Math.sqrt(dx*dx+dy*dy);
                if(d<90){ ctx.beginPath(); ctx.strokeStyle='rgba(30,95,168,'+(0.07*(1-d/90))+')';
                    ctx.lineWidth=.5; ctx.moveTo(pts[a].x,pts[a].y); ctx.lineTo(pts[b].x,pts[b].y); ctx.stroke(); }
            }
        }
        requestAnimationFrame(draw);
    }
    draw();

    /* ── Counter animation ── */
    document.querySelectorAll('.hs-num').forEach(function(el){
        var t=parseInt(el.dataset.target,10), s=null;
        function step(ts){ if(!s)s=ts; var p=Math.min((ts-s)/1400,1), e=1-Math.pow(1-p,3);
            el.textContent=Math.round(e*t); if(p<1) requestAnimationFrame(step); else el.textContent=t; }
        setTimeout(function(){ requestAnimationFrame(step); }, 500);
    });

    /* ── Typewriter ── */
    var tw = document.getElementById('typewriter');
    if(tw){
        var phrases=['Connecting to FASAH clearance portal...','Verifying SABER product conformity...','Syncing with ZATCA e-invoice system...','Loading Saudi ports and border data...','All systems operational — Ready.'];
        var pi=0,ci=0,del=false,wait=0;
        function type(){
            if(wait>0){wait--;setTimeout(type,40);return;}
            var ph=phrases[pi];
            if(!del){ tw.textContent=ph.slice(0,ci+1); ci++; if(ci===ph.length){del=true;wait=55;} setTimeout(type,40); }
            else { tw.textContent=ph.slice(0,ci-1); ci--; if(ci===0){del=false;wait=8;pi=(pi+1)%phrases.length;} setTimeout(type,20); }
        }
        type();
    }
})();
]]>
</script>
