<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"/>
<script type="text/javascript">
//<![CDATA[

/* ── Map initialisation ── */
(function() {
    var originCoords  = <t t-out="json.dumps(origin_coords)"/>;
    var destCoords    = <t t-out="json.dumps(dest_coords)"/>;
    var currentCoords = <t t-out="json.dumps(current_coords)"/>;
    var progress      = <t t-out="progress"/>;

    var mapEl = document.getElementById('trd-map');
    if (!mapEl) { return; }

    /* Centre map between origin and destination */
    var centerLat = (originCoords[0] + destCoords[0]) / 2;
    var centerLon = (originCoords[1] + destCoords[1]) / 2;

    /* Auto zoom based on distance */
    var latDiff = Math.abs(originCoords[0] - destCoords[0]);
    var lonDiff = Math.abs(originCoords[1] - destCoords[1]);
    var maxDiff = Math.max(latDiff, lonDiff);
    var zoom = maxDiff > 80 ? 3 : maxDiff > 30 ? 4 : maxDiff > 10 ? 5 : 6;

    var map = L.map('trd-map', { zoomControl: true, scrollWheelZoom: false }).setView([centerLat, centerLon], zoom);

    /* OpenStreetMap tiles — no API key needed */
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&#169; OpenStreetMap contributors',
        maxZoom: 18,
    }).addTo(map);

    /* Custom marker icons */
    function makeIcon(color, emoji) {
        return L.divIcon({
            className: '',
            html: '<div style="background:' + color + ';width:36px;height:36px;border-radius:50%;border:3px solid #fff;box-shadow:0 4px 12px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;font-size:16px;">' + emoji + '</div>',
            iconSize: [36, 36],
            iconAnchor: [18, 18],
            popupAnchor: [0, -20],
        });
    }

    /* Origin marker */
    L.marker(originCoords, { icon: makeIcon('#0d6efd', '&#x1F7E6;') })
        .addTo(map)
        .bindPopup('<strong>&#x1F4CD; Origin Port</strong><br/>Departure point');

    /* Destination marker */
    L.marker(destCoords, { icon: makeIcon('#059669', '&#x1F3C1;') })
        .addTo(map)
        .bindPopup('<strong>&#x1F3C1; Destination Port</strong><br/>Delivery point');

    /* Current position marker (only if different from origin/dest) */
    var sameAsOrigin = (currentCoords[0] === originCoords[0] && currentCoords[1] === originCoords[1]);
    var sameAsDest   = (currentCoords[0] === destCoords[0]   && currentCoords[1] === destCoords[1]);
    if (!sameAsOrigin && !sameAsDest) {
        L.marker(currentCoords, { icon: makeIcon('#f97316', '&#x1F6A2;') })
            .addTo(map)
            .bindPopup('<strong>&#x1F4CD; Current Position</strong><br/>Last known location')
            .openPopup();
    }

    /* Route polyline */
    var routePoints = [originCoords, currentCoords, destCoords].filter(function(p, i, arr) {
        return i === 0 || (p[0] !== arr[i-1][0] || p[1] !== arr[i-1][1]);
    });

    /* Dashed grey line for full route */
    L.polyline([originCoords, destCoords], {
        color: '#cbd5e1', weight: 2, dashArray: '6 6', opacity: .7,
    }).addTo(map);

    /* Solid blue line for completed portion */
    if (!sameAsOrigin) {
        L.polyline([originCoords, currentCoords], {
            color: '#0d6efd', weight: 3, opacity: .9,
        }).addTo(map);
    }
})();

/* ── Timeline scroll animation ── */
function animateTimeline() {
    var items = document.querySelectorAll('.trd-tl-item');
    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry, idx) {
            if (entry.isIntersecting) {
                var el = entry.target;
                var delay = parseInt(el.getAttribute('data-idx') || '0') * 80;
                setTimeout(function() { el.classList.add('visible'); }, delay);
                observer.unobserve(el);
            }
        });
    }, { threshold: 0.1 });
    items.forEach(function(item, idx) {
        item.setAttribute('data-idx', idx);
        observer.observe(item);
    });
}

/* ── Track Live button ── */
function scrollToMap() {
    var el = document.getElementById('trd-map');
    if (el) { el.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
}

document.addEventListener('DOMContentLoaded', function() {
    animateTimeline();
});
//]]>
</script>

