<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="customs_clearance_ksa.Dashboard" owl="1">
        <div class="o_customs_dashboard">

            <!-- 3D Globe Background -->
            <canvas t-ref="globeCanvas" class="globe-canvas"/>
            <div class="scanline-overlay"/>

            <!-- ── HEADER ─────────────────────────────────────────────────── -->
            <div class="dashboard-header">
                <div class="header-content">
                    <div class="header-left">
                        <div class="header-brand">
                            <span class="header-icon">⚖</span>
                            <div>
                                <h1>Customs Clearance KSA</h1>
                                <p>نظام التخليص الجمركي — Real-time monitoring</p>
                            </div>
                        </div>
                    </div>
                    <div class="header-center">
                        <div class="integration-pills">
                            <span class="ipill ipill-fasah"><span class="ipill-dot"/>FASAH</span>
                            <span class="ipill ipill-saber"><span class="ipill-dot"/>SABER</span>
                            <span class="ipill ipill-zatca"><span class="ipill-dot"/>ZATCA</span>
                            <span class="ipill ipill-sadad"><span class="ipill-dot"/>SADAD</span>
                        </div>
                    </div>
                    <div class="header-right">
                        <div class="header-clock">
                            <span class="clock-label">🕐 KSA</span>
                            <span class="clock-time"><t t-esc="state.currentTime || '--:--:--'"/></span>
                        </div>
                        <div class="header-actions">
                            <button class="btn-refresh" t-on-click="refreshDashboard" title="Refresh">↻</button>
                            <button class="btn-create" t-on-click="createNewClearance">+ New Clearance</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── MAIN CONTENT ───────────────────────────────────────────── -->
            <div class="dashboard-content">

                <!-- LEFT COLUMN -->
                <div class="left-column">

                    <!-- ── ROW 1: Shipment KPIs ──────────────────────────── -->
                    <div class="kpi-section-label">📦 Shipments &amp; Clearances</div>
                    <div class="kpi-grid">
                        <div class="kpi-card gradient-blue interactive" t-on-click="() => this.onKpiClick('total_shipments')">
                            <div class="kpi-icon">🚢</div>
                            <div class="kpi-content">
                                <div class="kpi-value" t-att-data-target="state.stats.total_shipments || 0">
                                    <t t-esc="state.stats.total_shipments || 0"/>
                                </div>
                                <div class="kpi-label">Active Shipments</div>
                                <div class="kpi-sub">الشحنات النشطة</div>
                            </div>
                            <div class="kpi-arrow">→</div>
                        </div>
                        <div class="kpi-card gradient-purple interactive" t-on-click="() => this.onKpiClick('in_customs')">
                            <div class="kpi-icon">⏳</div>
                            <div class="kpi-content">
                                <div class="kpi-value" t-att-data-target="state.stats.in_customs || 0">
                                    <t t-esc="state.stats.in_customs || 0"/>
                                </div>
                                <div class="kpi-label">In Review</div>
                                <div class="kpi-sub">قيد المراجعة</div>
                            </div>
                            <div class="kpi-arrow">→</div>
                        </div>
                        <div class="kpi-card gradient-orange interactive" t-on-click="() => this.onKpiClick('delayed')">
                            <div class="kpi-icon">⚠</div>
                            <div class="kpi-content">
                                <div class="kpi-value" t-att-data-target="state.stats.delayed || 0">
                                    <t t-esc="state.stats.delayed || 0"/>
                                </div>
                                <div class="kpi-label">Urgent</div>
                                <div class="kpi-sub">عاجل</div>
                            </div>
                            <div class="kpi-arrow">→</div>
                        </div>
                        <div class="kpi-card gradient-green interactive" t-on-click="() => this.onKpiClick('cleared_today')">
                            <div class="kpi-icon">✅</div>
                            <div class="kpi-content">
                                <div class="kpi-value" t-att-data-target="state.stats.cleared_today || 0">
                                    <t t-esc="state.stats.cleared_today || 0"/>
                                </div>
                                <div class="kpi-label">Cleared Today</div>
                                <div class="kpi-sub">تم تخليصه اليوم</div>
                            </div>
                            <div class="kpi-arrow">→</div>
                        </div>
                    </div>

                    <!-- ── ROW 2: Finance KPIs ────────────────────────────── -->
                    <div class="kpi-section-label">💰 Finance &amp; ZATCA</div>
                    <div class="kpi-grid kpi-grid-5">
                        <div class="kpi-card gradient-teal interactive" t-on-click="() => this.onKpiClick('revenue')">
                            <div class="kpi-icon">📈</div>
                            <div class="kpi-content">
                                <div class="kpi-value kpi-currency">
                                    <span class="currency-sym"><t t-esc="state.stats.currency || 'SAR'"/></span>
                                    <t t-esc="state.stats.monthly_revenue || '0'"/>
                                </div>
                                <div class="kpi-label">Revenue (Month)</div>
                                <div class="kpi-sub">الإيرادات الشهرية</div>
                            </div>
                        </div>
                        <div class="kpi-card gradient-profit interactive" t-on-click="() => this.onKpiClick('net_profit')">
                            <div class="kpi-icon">💹</div>
                            <div class="kpi-content">
                                <div class="kpi-value kpi-currency">
                                    <span class="currency-sym"><t t-esc="state.stats.currency || 'SAR'"/></span>
                                    <t t-esc="state.stats.monthly_profit || '0'"/>
                                </div>
                                <div class="kpi-label">Net Profit</div>
                                <div class="kpi-sub">صافي الربح</div>
                            </div>
                        </div>
                        <div class="kpi-card gradient-receivable interactive" t-on-click="() => this.onKpiClick('pending_invoices')">
                            <div class="kpi-icon">🧾</div>
                            <div class="kpi-content">
                                <div class="kpi-value" t-att-data-target="state.stats.pending_invoices || 0">
                                    <t t-esc="state.stats.pending_invoices || 0"/>
                                </div>
                                <div class="kpi-label">Pending Invoices</div>
                                <div class="kpi-sub"><t t-esc="state.stats.currency || 'SAR'"/> <t t-esc="state.stats.pending_amount || '0'"/></div>
                            </div>
                        </div>
                        <div class="kpi-card gradient-zatca-ok interactive" t-on-click="() => this.onKpiClick('zatca_cleared')">
                            <div class="kpi-icon">🛡</div>
                            <div class="kpi-content">
                                <div class="kpi-value" t-att-data-target="state.stats.zatca_cleared || 0">
                                    <t t-esc="state.stats.zatca_cleared || 0"/>
                                </div>
                                <div class="kpi-label">ZATCA Cleared</div>
                                <div class="kpi-sub">معتمد من زاتكا</div>
                            </div>
                        </div>
                        <div class="kpi-card gradient-zatca-wait interactive" t-on-click="() => this.onKpiClick('zatca_pending')">
                            <div class="kpi-icon">📤</div>
                            <div class="kpi-content">
                                <div class="kpi-value" t-att-data-target="state.stats.zatca_pending || 0">
                                    <t t-esc="state.stats.zatca_pending || 0"/>
                                </div>
                                <div class="kpi-label">ZATCA Pending</div>
                                <div class="kpi-sub">بانتظار زاتكا</div>
                            </div>
                        </div>
                    </div>

                    <!-- ── Revenue / Profit Line Chart ────────────────────── -->
                    <div class="chart-box chart-box-line">
                        <div class="chart-header-row">
                            <div class="chart-title">📊 Revenue &amp; Profit Trend (6 months)</div>
                            <div class="chart-hint">إيرادات وأرباح آخر 6 أشهر</div>
                        </div>
                        <canvas t-ref="revenueChart" style="height:200px"/>
                    </div>

                    <!-- ── Status Doughnut Chart ──────────────────────────── -->
                    <div class="chart-box">
                        <div class="chart-header-row">
                            <div class="chart-title">🔄 Clearance Status Distribution</div>
                            <div class="chart-hint">Click segments to filter</div>
                        </div>
                        <canvas t-ref="statusChart" style="height:260px"/>
                    </div>

                </div>

                <!-- RIGHT COLUMN -->
                <div class="right-column">

                    <!-- ── ZATCA Status Panel ─────────────────────────────── -->
                    <div class="zatca-panel">
                        <div class="zatca-panel-header">
                            <span class="zatca-title">🛡 ZATCA Invoice Status</span>
                            <div class="zatca-legend">
                                <span class="zleg zleg-ok">● Cleared</span>
                                <span class="zleg zleg-wait">● Pending</span>
                                <span class="zleg zleg-err">● Error</span>
                            </div>
                        </div>
                        <div class="zatca-table-wrap">
                            <table class="zatca-table">
                                <thead>
                                    <tr>
                                        <th>Invoice</th>
                                        <th>Customer</th>
                                        <th>Amount</th>
                                        <th>ZATCA</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="state.recent_invoices and state.recent_invoices.length > 0">
                                        <t t-foreach="state.recent_invoices" t-as="inv" t-key="inv.id">
                                            <tr class="zatca-row" t-on-click="() => this.openInvoice(inv.id)">
                                                <td class="inv-ref"><t t-esc="inv.name"/></td>
                                                <td class="inv-partner"><t t-esc="inv.partner"/></td>
                                                <td class="inv-amt"><t t-esc="inv.currency"/> <t t-esc="inv.total"/></td>
                                                <td>
                                                    <span t-attf-class="zatca-badge zatca-{{ inv.zatca_status }}">
                                                        <t t-if="inv.zatca_status === 'cleared'">✓ Cleared</t>
                                                        <t t-elif="inv.zatca_status === 'submitted'">↑ Submitted</t>
                                                        <t t-elif="inv.zatca_status === 'error'">✗ Error</t>
                                                        <t t-else="">⏸ Pending</t>
                                                    </span>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <tr><td colspan="4" class="no-data">No invoices yet</td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- ── Recent Clearances Table ────────────────────────── -->
                    <div class="clearance-table">
                        <div class="table-header-row">
                            <div class="table-title">🗂 Recent Clearances</div>
                            <div class="table-filters">
                                <button t-attf-class="filter-btn {{ state.selectedFilter === 'all' ? 'active' : '' }}"
                                        t-on-click="() => this.filterClearances('all')">All</button>
                                <button t-attf-class="filter-btn {{ state.selectedFilter === 'pending' ? 'active' : '' }}"
                                        t-on-click="() => this.filterClearances('pending')">Pending</button>
                                <button t-attf-class="filter-btn {{ state.selectedFilter === 'cleared' ? 'active' : '' }}"
                                        t-on-click="() => this.filterClearances('cleared')">Cleared</button>
                            </div>
                        </div>
                        <div class="table-wrapper">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Reference</th>
                                        <th>Partner</th>
                                        <th>Type</th>
                                        <th>Status</th>
                                        <th>Progress</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="this.filteredClearances.length > 0">
                                        <t t-foreach="this.filteredClearances" t-as="item" t-key="item.id">
                                            <tr t-on-click="() => this.openClearance(item.id)" class="interactive-row">
                                                <td class="ref-col"><t t-esc="item.name"/></td>
                                                <td><t t-esc="item.partner_name"/></td>
                                                <td><span class="type-badge"><t t-esc="item.type"/></span></td>
                                                <td>
                                                    <span t-attf-class="status-pill {{ this.getStatusClass(item.state) }}">
                                                        <t t-esc="item.state_label"/>
                                                    </span>
                                                </td>
                                                <td>
                                                    <div class="progress-bar-wrapper">
                                                        <div class="progress-bar-fill" t-attf-style="width: {{ item.progress }}%"/>
                                                        <span class="progress-text"><t t-esc="item.progress"/>%</span>
                                                    </div>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <tr><td colspan="5" class="no-data">
                                            <div class="no-data-message">No clearances found</div>
                                        </td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </t>
</templates>
